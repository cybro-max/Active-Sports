// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'league' | 'team' | 'player'
  entityId  Int
  name      String
  logo      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, entityId])
}

model SyncStatus {
  id        String   @id @default(cuid())
  job       String   @unique
  lastRun   DateTime
  lastError String?
  nextRun   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model League {
  id        Int      @id
  name      String
  type      String
  logo      String
  country   String
  flag      String?
  code      String?
  season    Int
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([name])
}

model ContentCache {
  key         String   @id
  content     String
  generatedAt DateTime @default(now())
  model       String
}

model ApiCache {
  key       String   @id
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model Team {
  id          Int      @id
  name        String
  logo        String
  country     String?
  venueName   String?
  venueId     Int?
  leagueId    Int?
  leagueName  String?
  updatedAt   DateTime @updatedAt
  players     Player[]

  @@index([name])
}

model Player {
  id          Int      @id
  name        String
  firstname   String?
  lastname    String?
  age         Int?
  nationality String?
  height      String?
  weight      String?
  photo       String?
  team        Team?    @relation(fields: [teamId], references: [id])
  teamId      Int?
  position    String?
  number      Int?
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([teamId])
  @@index([position])
}
